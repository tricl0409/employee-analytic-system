# ============================================================
#  .gitignore — Employee Analytic System (Python / Streamlit)
# ============================================================


# ───────────────────────────────────────────
# Python
# ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
pyrightconfig.json


# ───────────────────────────────────────────
# Streamlit
# ───────────────────────────────────────────
.streamlit/secrets.toml

# Allow sample / reference data you intentionally commit
# !data/sample_*.csv


# ───────────────────────────────────────────
# Logs & temporary files
# ───────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*.swo
~$*


# ───────────────────────────────────────────
# Jupyter Notebooks checkpoints
# ───────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ───────────────────────────────────────────
# IDE / Editor
# ───────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace


# ───────────────────────────────────────────
# OS generated
# ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini


# ───────────────────────────────────────────
# AI / Tool config (local only)
# ───────────────────────────────────────────
.gemini/
